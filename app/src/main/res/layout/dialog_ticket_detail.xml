<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/iv_close_details"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/black" />

        <TextView
            android:id="@+id/tv_detail_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="32dp"
            android:text="Chi tiết phiếu bán BH00000001"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/detail_divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/tv_detail_title"
            android:layout_marginTop="8dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/tv_detail_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/detail_divider1"
            android:layout_marginTop="12dp"
            android:text="Ngày bán"
            android:textColor="@color/text_gray"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_detail_date_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_detail_date_label"
            android:text="10-04-2025"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_detail_list_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_detail_date_value"
            android:layout_marginTop="16dp"
            android:text="Danh sách hàng hóa"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Mock Table -->
        <TableLayout
            android:id="@+id/tl_items"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_detail_list_label"
            android:layout_marginTop="8dp"
            android:stretchColumns="0">

            <!-- Table Header -->
            <TableRow android:background="#F5F5F5">
                <TextView android:padding="8dp" android:text="Tên SP" android:textColor="@color/text_gray" android:gravity="center" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="Số lượng" android:textColor="@color/text_gray" android:gravity="center" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="Đơn giá" android:textColor="@color/text_gray" android:gravity="center" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="Thành tiền" android:textColor="@color/text_gray" android:gravity="center" android:background="@drawable/table_cell_bg" />
            </TableRow>

            <!-- Row 1 -->
            <TableRow>
                <TextView android:padding="8dp" android:text="Mỳ SiuKay Phô Mai" android:textColor="@color/black" android:textSize="13sp" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="10" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="12.000" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="120.000" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
            </TableRow>

            <!-- Row 2 -->
            <TableRow>
                <TextView android:padding="8dp" android:text="Mỳ hảo hảo" android:textColor="@color/black" android:textSize="13sp" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="10" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="5.000" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
                <TextView android:padding="8dp" android:text="50.000" android:gravity="center" android:textColor="@color/black" android:background="@drawable/table_cell_bg" />
            </TableRow>

        </TableLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tl_items"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng thành tiền: "
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_detail_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="170.000 đ"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>