<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cố định kích thước tổng thể là 16dp -->
    <item android:width="16dp" android:height="16dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <stroke
                android:width="1dp"
                android:color="#CBD5E1" />
            <corners android:radius="4dp" />
        </shape>
    </item>
    <!-- Dấu tích đen nằm gọn bên trong -->
    <item
        android:width="12dp"
        android:height="12dp"
        android:gravity="center">
        <vector
            android:width="12dp"
            android:height="12dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            <path
                android:fillColor="@color/black"
                android:pathData="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41,-1.41L9,16.17z"/>
        </vector>
    </item>
</layer-list>
